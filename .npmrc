node-linker=hoisted
catalog.react=18.3.0
catalog.@types/react=19.0.10
catalog.@types/react-dom=19.0.4

# Allow local pnpm versions below package.json's packageManager pin (recommended: pnpm 10.8.1 via corepack or npm i -g pnpm@10.8.1)
package-manager-strict=false

# Prevent React version conflicts in mobile package
public-hoist-pattern[]=!react
public-hoist-pattern[]=!react-dom
public-hoist-pattern[]=!react-native