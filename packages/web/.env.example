### The fastest way to get started is just to add your OpenAI API key to the .env file.
OPENAI_API_KEY="sk-xxxx"
OPENAI_API_BASE=""  # The base URL for OpenAI API
# OPENAI_WHISPER_BASE_URL=  # Optional; Whisper/transcription endpoint (defaults to OPENAI_API_BASE)
GROQ_API_KEY="gsk-xxxx"
GROQ_API_BASE=""  # The base URL for Groq API
ANTHROPIC_API_KEY="sk-xxxx"
ANTHROPIC_API_BASE=""  # The base URL for Anthropic API
GOOGLE_API_KEY="sk-xxxx"
GOOGLE_API_BASE=""  # The base URL for Google API
DEEPSEEK_API_KEY="sk-xxxx"
DEEPSEEK_API_BASE=""  # The base URL for DeepSeek API
MISTRAL_API_KEY="sk-xxxx"  # The API key for Mistral AI OCR

# AI models (OpenAI). Unset → MODEL_PROVIDER=openai, MODEL_NAME=gpt-4.1-mini
# MODEL_PROVIDER=openai
# MODEL_NAME=gpt-4.1-mini              # Organizer, classify, tag, extract
# RESPONSES_MODEL_NAME=gpt-4.1-mini    # Chat + web search (OpenAI Responses API only; defaults to MODEL_NAME)
#
# Cost-oriented split (OpenAI list prices per 1M tokens, standard tier):
#   gpt-4.1-mini     $0.40 in / $1.60 out  — default, cheapest all-in-one
#   gpt-5.4-nano     $0.20 in / $1.25 out  — bulk/organizer (MODEL_NAME)
#   gpt-5.4-mini     $0.75 in / $4.50 out — chat (RESPONSES_MODEL_NAME); ~1.5–3× vs 4.1-mini with reasoning
# Example: MODEL_NAME=gpt-5.4-nano and RESPONSES_MODEL_NAME=gpt-5.4-mini
#
# Chat web search: on by default when MODEL_PROVIDER=openai. ~$10 per 1,000 search calls (same for any model).
# CHAT_WEB_SEARCH=false
# CHAT_DEEP_SEARCH=true   # Medium search context (default off)
# CHAT_REASONING_EFFORT=none  # none | low | medium | high (default none — less draft-then-revise in chat)

# Chat API: max user turns kept server-side (unset or invalid → 30; 0 or negative → no limit)
# CHAT_MAX_USER_TURNS=30

# Loops API key for newsletter and contact management
LOOPS_API_KEY="your-loops-api-key"
