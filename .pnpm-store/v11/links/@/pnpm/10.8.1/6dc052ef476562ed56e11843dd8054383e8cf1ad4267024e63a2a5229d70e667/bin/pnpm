#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../node_modules/pnpm/bin/pnpm.cjs" "$@"
else
  exec node  "$basedir/../node_modules/pnpm/bin/pnpm.cjs" "$@"
fi
# cmd-shim-target=/Users/jean-philippefong/Documents/test-local-vault/test-local-vault/.obsidian/plugins/note-companion/.pnpm-store/v11/links/@/pnpm/10.8.1/6dc052ef476562ed56e11843dd8054383e8cf1ad4267024e63a2a5229d70e667/node_modules/pnpm/bin/pnpm.cjs
