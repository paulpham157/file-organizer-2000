{
  "name": "file-organizer-2000-monorepo",
  "private": true,
  "workspaces": [
    "packages/plugin"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.13.10",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "globals": "^17.6.0",
    "node-gyp": "^11.1.0",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.59.1"
  },
  "version": "1.0.0",
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "build": "pnpm --dir packages/plugin run build",
    "build:all": "turbo build",
    "dev": "turbo dev",
    "lint": "eslint .",
    "lint:plugin": "eslint packages/plugin",
    "lint:obsidian-scan": "OBSIDIAN_SCAN=1 eslint packages/plugin",
    "lint:monorepo": "turbo lint",
    "test": "turbo test",
    "clean": "git clean -xdf node_modules",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "pnpm": {
    "patchedDependencies": {
      "xcode@3.0.1": "patches/xcode@3.0.1.patch"
    },
    "overrides": {
      "@types/react": "19.0.10",
      "@types/react-dom": "19.0.4",
      "@types/react@^19.0.0": "19.0.10",
      "@types/react-dom@^19.0.0": "19.0.4",
      "zod": "^3.25.76",
      "fast-xml-parser": "^4.5.4",
      "picomatch": "^2.3.2",
      "lodash": "^4.17.23",
      "minimatch@3": "^3.1.3",
      "minimatch@8": "^8.0.5",
      "minimatch@9": "^9.0.6",
      "brace-expansion@1": "^1.1.12",
      "brace-expansion@2": "^2.0.2",
      "flatted": "^3.4.0",
      "qs": "^6.14.2",
      "csstype": "^3.2.3"
    },
    "onlyBuiltDependencies": [
      "@ffprobe-installer/darwin-arm64",
      "@ffprobe-installer/linux-x64",
      "ffmpeg-static"
    ]
  }
}
